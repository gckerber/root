{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": { "isEnabled": true, "excludedTypes": "Request" }
    },
    "logLevel": {
      "default": "Warning",
      "Host.Results": "Error",
      "Function": "Error"
    }
  },
  "extensions": {
    "http": { "routePrefix": "api" }
  },
  "functionTimeout": "00:05:00"
}
